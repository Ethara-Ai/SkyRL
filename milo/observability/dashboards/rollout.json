{
  "_dashboard_id": "milo_rollout",
  "title": "Milo — Rollout Diagnostics",
  "audience": "RL engineer",
  "sections": [
    {
      "name": "Rollout structure",
      "panels": [
        { "type": "histogram", "metric": "rollout/episode_length"    },
        { "type": "histogram", "metric": "rollout/tool_calls_used"   },
        { "type": "histogram", "metric": "rollout/episode_seconds"   },
        { "type": "scalar",    "metric": "rollout/termination_breakdown" }
      ]
    },
    {
      "name": "Per-language reward",
      "panels": [
        { "type": "bar", "metric": "rollout/mean_r_total_by_lang"   },
        { "type": "bar", "metric": "rollout/pass_rate_by_lang"      }
      ]
    },
    {
      "name": "Per-tier reward",
      "panels": [
        { "type": "bar", "metric": "rollout/mean_r_total_by_tier"   },
        { "type": "bar", "metric": "rollout/pass_rate_by_tier"      }
      ]
    }
  ]
}
