        { "type": "line",    "metric": "train/loss_kl",              "title": "KL loss" },
        { "type": "line",    "metric": "train/grad_norm_post_clip",  "title": "Grad norm (post-clip)" }
      ]
    },
    {
      "name": "Reward decomposition",
      "panels": [
        { "type": "line", "metric": "rollout/mean_r_total",    "title": "R_total" },
        { "type": "line", "metric": "rollout/mean_r_terminal", "title": "R_terminal" },
        { "type": "line", "metric": "rollout/mean_r_rubric",   "title": "R_rubric (mean)" }
      ]
    },
    {
      "name": "Alarms",
      "panels": [
        { "type": "scalar", "metric": "alarm/image_pull_failure_rate" },
