# Phase 18.3 — Milo gym Docker image (thin layer over SkyRL base).
# Used by the policy serving deployment (milo/k8s/serve.yaml) and as the
# sandbox base for per-rollout containers.

FROM nvidia/cuda:12.4.0-cudnn-devel-ubuntu22.04 AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PIP_PROGRESS_BAR=off

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl git python3.12 python3.12-venv python3-pip \
      build-essential patch \
 && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
 && mv /root/.local/bin/uv /usr/local/bin/uv

WORKDIR /workspace
COPY pyproject.toml uv.lock README.md ./
COPY skyrl/        skyrl/
COPY skyrl-agent/  skyrl-agent/
COPY skyrl-gym/    skyrl-gym/
COPY skyrl-train/  skyrl-train/
COPY skyrl-tx/     skyrl-tx/
COPY examples/     examples/
COPY milo/         milo/
COPY docker/       docker/

# Install with the gym-relevant extras only (vllm + miniswe + dev).
RUN uv sync --frozen --extra fsdp --extra miniswe --extra dev || \
    uv sync --extra fsdp --extra miniswe --extra dev

EXPOSE 8000

# Sentinel ENV vars — overridden at runtime.
ENV EVAL_DOCKER_IMAGE_PREFIX="426628337772.dkr.ecr.ap-south-1.amazonaws.com/rfp-coding-q1"
ENV MILO_JUDGE_MODEL="claude-opus-4-6"

CMD ["bash"]
